{
  "manifest_version": 3,
  "name": "PrismRail",
  "version": "0.1.0",
  "description": "Glass-style timeline rail for long AI conversations.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://deepseek.com/*",
    "https://www.deepseek.com/*",
    "https://chat.deepseek.com/*",
    "https://doubao.com/*",
    "https://www.doubao.com/*",
    "https://inhouse.doubao.com/*",
    "https://chatglm.cn/*",
    "https://www.chatglm.cn/*",
    "https://z.ai/*",
    "https://www.z.ai/*",
    "https://chat.z.ai/*",
    "https://grok.com/*",
    "https://www.grok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/prismrail-16.png",
    "32": "icons/prismrail-32.png",
    "48": "icons/prismrail-48.png",
    "128": "icons/prismrail-128.png"
  },
  "action": {
    "default_title": "PrismRail",
    "default_icon": {
      "16": "icons/prismrail-16.png",
      "32": "icons/prismrail-32.png",
      "48": "icons/prismrail-48.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://deepseek.com/*",
        "https://www.deepseek.com/*",
        "https://chat.deepseek.com/*",
        "https://doubao.com/*",
        "https://www.doubao.com/*",
        "https://inhouse.doubao.com/*",
        "https://chatglm.cn/*",
        "https://www.chatglm.cn/*",
        "https://z.ai/*",
        "https://www.z.ai/*",
        "https://chat.z.ai/*",
        "https://grok.com/*",
        "https://www.grok.com/*"
      ],
      "js": ["content.bundle.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
